# Developer plans only. If unset, `letta server` starts OAuth device flow
# and prints an authorization URL in the logs (recommended).
# LETTA_API_KEY=your-api-key-here

ENV_NAME=cloud

# Required for self-hosted deployments.
# LETTA_BASE_URL=http://localhost:8283

# Force file-based token persistence instead of keychain if needed.
# LETTA_SKIP_KEYCHAIN_CHECK=1

# ── Channels (optional) ─────────────────────────────────────────────
# Set any of the below to enable Letta Code channels on container start.
# On first boot the entrypoint writes ~/.letta/channels/<channel>/accounts.json;
# on subsequent restarts it's preserved so pairings survive.

# Telegram: get a bot token from https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DM_POLICY=pairing   # pairing | allowlist | open

# Slack: see https://docs.letta.com/letta-code/channels for the app manifest
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_DM_POLICY=open         # open | allowlist
